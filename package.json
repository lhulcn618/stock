                            "@tauri-apps/cli":  "^2.2.5",
                            "@types/react":  "^18.3.12",
                            "@types/react-dom":  "^18.3.1",
                            "@vitejs/plugin-react":  "^4.3.4",
                            "typescript":  "^5.7.2",
                            "vite":  "^6.0.3"
                        }
}
